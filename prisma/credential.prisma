// =============================================================================
//  PocVault — id/pw 인증 전용 DB 스키마
// =============================================================================
//  이 스키마는 **오직 id/pw 로그인 사용자의 데이터**만 보관한다.
//  Google 로그인의 데이터는 prisma/google.prisma 쪽 DB 에 격리 저장된다.
//  두 DB 는 파일 자체가 다르며, 어떤 코드도 동시에 두 DB 에 접근하지 않는다.
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/credential"
}

datasource credentialDb {
  provider = "sqlite"
  url      = env("CREDENTIAL_DATABASE_URL")
}

/// id/pw 계정 1개 = 1행 (1 loginId = 1 row, unique)
model CredentialUser {
  id             String    @id @default(cuid())
  loginId        String    @unique
  passwordHash   String
  storageQuota   Int       @default(1073741824) // 1 GiB
  usedStorage    Int       @default(0)
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Optional linkage to a GoogleUser.id (stored as string because DBs are separate).
  // This allows at-most-N CredentialUser accounts to be created per Google user,
  // enforced at the application level.
  googleOwnerId  String?   

  files CredentialFile[]
  texts CredentialText[]

  @@index([loginId])
  @@index([isActive])
  @@index([googleOwnerId])
}

model CredentialFile {
  id          String   @id @default(cuid())
  userId      String
  filename    String
  storedName  String
  mimeType    String
  size        Int
  storagePath String
  description String?
  createdAt   DateTime @default(now())

  user CredentialUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CredentialText {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  tags      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user CredentialUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}
